# Copy this file to .env for local development. The bridge, smoke script, and
# agent load repo-local .env automatically without overriding variables already
# supplied by your shell or MCP client.
#
# MCP clients may also set VELOCIRAPTOR_ENV_FILE=/absolute/path/to/.env to load
# a dotenv file from another location. Direct MCP client env values still win.

# Path to the Velociraptor API client config generated by:
# velociraptor --config /etc/velociraptor/server.config.yaml config api_client --name api --role administrator,api api_client.yaml
VELOCIRAPTOR_API_CONFIG=/absolute/path/to/api_client.yaml

# Optional default org for multi-tenant Velociraptor deployments.
# Leave blank to use the root/default org.
VELOCIRAPTOR_ORG_ID=

# Enable raw VQL request logging through Python logging.
# Keep disabled unless actively debugging.
VELOCIRAPTOR_DEBUG_VQL=0

# Enable disruptive tools: run_vql, quarantine_host, and kill_process.
# Keep disabled unless you explicitly accept endpoint impact risk.
ENABLE_DANGEROUS_TOOLS=false

# Agent POC settings.
OLLAMA_MODEL=gemma4:e2b
VELOCIRAPTOR_AGENT_VERBOSE=0
